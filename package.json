{
  "name": "public-monorepo",
  "description": "My monorepo",
  "keywords": [],
  "license": "ISC",
  "author": "Kishore",
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "changeset": "changeset",
    "check": "vp check",
    "clean": "del-cli '**/node_modules' '**/dist'",
    "dev": "vp run -r dev",
    "fmt": "vp fmt",
    "lint": "vp check && pnpm lint:syncpack && pnpm -r --no-sort --workspace-concurrency=4 lint",
    "lint:syncpack": "syncpack lint",
    "outdated": "pnpm outdated --recursive",
    "pnpm:outdated": "pnpm outdated --recursive",
    "release": "pnpm changeset publish",
    "subtrees:update": "bash scripts/update-subtrees.sh",
    "syncpack:fix": "syncpack fix",
    "syncpack:outdated": "syncpack update --check --no-cache --target minor",
    "syncpack:update": "syncpack update --interactive --target minor",
    "syncpack:update:latest": "syncpack update --interactive --target latest",
    "test": "vp run -r test",
    "updates": "npx -y npm-check-updates -iws",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "del-cli": "catalog:",
    "syncpack": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
