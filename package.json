{
  "name": "public-monorepo",
  "description": "My monorepo",
  "keywords": [],
  "license": "ISC",
  "author": "Kishore",
  "type": "module",
  "scripts": {
    "build": "vp run -r build",
    "changeset": "changeset",
    "check": "vp check",
    "clean": "del-cli '**/node_modules' '**/dist'",
    "dev": "vp run -r dev",
    "fmt": "vp fmt",
    "gh:version": "GITHUB_TOKEN=$(gh auth token --user pkishorez) pnpm changeset version",
    "lint": "vp check && pnpm -r --no-sort --workspace-concurrency=4 lint",
    "release": "pnpm changeset publish",
    "subtrees:update": "bash scripts/update-subtrees.sh",
    "test": "vp run -r test",
    "updates": "npx -y npm-check-updates -iws",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "del-cli": "7.0.0",
    "typescript": "7.0.2",
    "vite-plus": "0.2.5"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "packageExtensions": {
      "dependency-cruiser@18.0.0": {
        "peerDependencies": {
          "typescript": ">=2.0.0 <7.0.0"
        }
      }
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@content-collections/vite>vite": "8",
        "bun-ffi-structs>typescript": "7"
      }
    }
  }
}
