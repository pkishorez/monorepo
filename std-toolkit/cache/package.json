{
  "name": "@std-toolkit/cache",
  "version": "0.0.1",
  "private": true,
  "description": "Effect-based cache with IndexedDB support for EntityType storage",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./idb": {
      "types": "./dist/idb/index.d.ts",
      "default": "./dist/idb/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "default": "./dist/memory/index.js"
    },
    "./vtest-report": "./vtest/report.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "fmt": "vp fmt",
    "test:docs": "vitest run --config vitest.docs.config.ts",
    "test:docs:watch": "vitest run --config vitest.docs.config.ts --watch",
    "lint": "vp check && pnpm lint:tsc",
    "lint:tsc": "tsc --noEmit",
    "test": "vp test",
    "test:watch": "vp test --watch"
  },
  "dependencies": {
    "@std-toolkit/core": "workspace:*",
    "idb": "8.0.3"
  },
  "devDependencies": {
    "@monorepo/vtest": "workspace:*",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.8.0",
    "effect": "3.21.2",
    "fake-indexeddb": "6.2.5",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "effect": ">=3.0.0"
  }
}
