{
  "name": "std-toolkit",
  "version": "0.0.1",
  "private": false,
  "description": "Single-table design toolkit — database-agnostic sync over single-table item collections, with schema evolution, DynamoDB/SQLite adapters, and TanStack DB integration",
  "keywords": [
    "dynamodb",
    "effect",
    "indexeddb",
    "schema",
    "single table design",
    "sqlite",
    "sync",
    "tanstack"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pkishorez/monorepo"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./eschema": {
      "types": "./dist/eschema/index.d.ts",
      "default": "./dist/eschema/index.js"
    },
    "./eschema/*": {
      "types": "./dist/eschema/*",
      "import": "./dist/eschema/*"
    },
    "./dynamodb": {
      "types": "./dist/db/dynamodb/index.d.ts",
      "default": "./dist/db/dynamodb/index.js"
    },
    "./dynamodb/*": {
      "types": "./dist/db/dynamodb/*",
      "import": "./dist/db/dynamodb/*"
    },
    "./idb": {
      "types": "./dist/db/idb/src/index.d.ts",
      "default": "./dist/db/idb/src/index.js"
    },
    "./idb/*": {
      "types": "./dist/db/idb/src/*",
      "import": "./dist/db/idb/src/*"
    },
    "./sqlite": {
      "types": "./dist/db/sqlite/index.d.ts",
      "default": "./dist/db/sqlite/index.js"
    },
    "./sqlite/adapters/do": {
      "types": "./dist/db/sqlite/sql/adapters/do.d.ts",
      "default": "./dist/db/sqlite/sql/adapters/do.js"
    },
    "./sqlite/adapters/better-sqlite3": {
      "types": "./dist/db/sqlite/sql/adapters/better-sqlite3.d.ts",
      "default": "./dist/db/sqlite/sql/adapters/better-sqlite3.js"
    },
    "./sqlite/adapters/bun": {
      "types": "./dist/db/sqlite/sql/adapters/bun.d.ts",
      "default": "./dist/db/sqlite/sql/adapters/bun.js"
    },
    "./sqlite/adapters/node": {
      "types": "./dist/db/sqlite/sql/adapters/node.d.ts",
      "default": "./dist/db/sqlite/sql/adapters/node.js"
    },
    "./tanstack-sync": {
      "types": "./dist/tanstack-sync/index.d.ts",
      "default": "./dist/tanstack-sync/index.js"
    },
    "./tanstack-sync/paced": {
      "types": "./dist/tanstack-sync/paced/index.d.ts",
      "default": "./dist/tanstack-sync/paced/index.js"
    },
    "./tanstack-sync/offline-storage/idb": {
      "types": "./dist/tanstack-sync/offline-storage/adapters/idb/index.d.ts",
      "default": "./dist/tanstack-sync/offline-storage/adapters/idb/index.js"
    }
  },
  "bin": {
    "eschema": "dist/eschema/cli/main.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dynamodb:generate": "bun scripts/dynamodb/generate.ts",
    "fmt": "vp fmt",
    "lint": "vp check && pnpm lint:tsc",
    "lint:depcruise": "depcruise-viz lint",
    "lint:tsc": "tsc --noEmit",
    "sqlite:play": "bun src/db/sqlite/play.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "@standard-schema/spec": "1.1.0",
    "aws4fetch": "1.0.20",
    "idb": "8.0.3",
    "kleur": "4.1.5",
    "type-fest": "5.7.0",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260703.1",
    "@tanstack/query-db-collection": "1.0.46",
    "@tanstack/react-db": "0.1.92",
    "@tsconfig/node22": "22.0.5",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "better-sqlite3": "12.11.1",
    "depcruise-viz": "workspace:*",
    "effect": "4.0.0-beta.78",
    "fake-indexeddb": "6.2.5",
    "react": "19.2.7",
    "typescript": "7.0.2",
    "vite-plus": "0.2.5",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "@tanstack/react-db": ">=0.1.64",
    "effect": "4.0.0-beta.78",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-db": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  }
}
