{
  "name": "@std-toolkit/eschema",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@standard-schema/spec": "1.1.0"
  },
  "devDependencies": {
    "@effect/vitest": "0.29.0",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.6.0",
    "effect": "3.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "effect": ">=3.0.0"
  }
}
