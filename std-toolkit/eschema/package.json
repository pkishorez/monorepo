{
  "name": "@std-toolkit/eschema",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "eschema": "./dist/cli/main.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:cli": "tsx --tsconfig tsconfig.json src/cli/main.ts",
    "fmt": "vp fmt",
    "lint": "vp check && pnpm lint:tsc",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "@standard-schema/spec": "1.1.0",
    "kleur": "4.1.5"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.9.1",
    "effect": "4.0.0-beta.78",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.78"
  }
}
