{
  "name": "@std-toolkit/sqlite",
  "version": "0.0.1",
  "private": true,
  "description": "SQLite utilities with Effect",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "default": "./dist/rpc/index.js"
    },
    "./adapters/do": {
      "types": "./dist/sql/adapters/do.d.ts",
      "default": "./dist/sql/adapters/do.js"
    },
    "./adapters/better-sqlite3": {
      "types": "./dist/sql/adapters/better-sqlite3.d.ts",
      "default": "./dist/sql/adapters/better-sqlite3.js"
    },
    "./adapters/bun": {
      "types": "./dist/sql/adapters/bun.d.ts",
      "default": "./dist/sql/adapters/bun.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "play": "pnpm tsx ./play/play.ts",
    "test": "vitest",
    "test:bun": "bun test .bun.",
    "test:run": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@std-toolkit/core": "workspace:*",
    "@std-toolkit/eschema": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260414.1",
    "@effect/rpc": "0.75.0",
    "@effect/vitest": "0.29.0",
    "@tsconfig/node22": "22.0.5",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "better-sqlite3": "12.9.0",
    "effect": "3.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "@effect/rpc": ">=0.73.0",
    "effect": ">=3.0.0"
  }
}
