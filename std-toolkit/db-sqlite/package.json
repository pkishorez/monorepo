{
  "name": "@std-toolkit/sqlite",
  "version": "0.0.1",
  "private": true,
  "description": "SQLite utilities with Effect",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "default": "./dist/rpc/index.js"
    },
    "./adapters/do": {
      "types": "./dist/sql/adapters/do.d.ts",
      "default": "./dist/sql/adapters/do.js"
    },
    "./adapters/better-sqlite3": {
      "types": "./dist/sql/adapters/better-sqlite3.d.ts",
      "default": "./dist/sql/adapters/better-sqlite3.js"
    },
    "./adapters/bun": {
      "types": "./dist/sql/adapters/bun.d.ts",
      "default": "./dist/sql/adapters/bun.js"
    },
    "./adapters/node": {
      "types": "./dist/sql/adapters/node.d.ts",
      "default": "./dist/sql/adapters/node.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "fmt": "vp fmt",
    "lint": "vp check && pnpm lint:tsc",
    "lint:tsc": "tsc --noEmit",
    "play": "pnpm tsx ./src/play.ts",
    "test": "vitest run",
    "test:bun": "bun test .bun.",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@std-toolkit/core": "workspace:*",
    "@std-toolkit/eschema": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260517.1",
    "@tsconfig/node22": "22.0.5",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "better-sqlite3": "12.10.0",
    "effect": "4.0.0-beta.78",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.78"
  },
  "engines": {
    "node": ">=24"
  }
}
