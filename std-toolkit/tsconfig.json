{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "src/eschema/cli/__tests__/fixtures/**",
    "src/dynamodb/depcruise.config.ts",
    "src/tanstack-sync/depcruise.config.ts",
    "src/sqlite/sql/adapters/bun.ts",
    "src/sqlite/sql/adapters/__tests__/bun.bun.test.ts",
    "src/sqlite/sql/adapters/__tests__/compat.bun.test.ts",
    "src/sqlite/sql/adapters/__tests__/compat-read-better-sqlite3.ts",
    "src/sqlite/sql/adapters/__tests__/compat-seed-better-sqlite3.ts"
  ]
}
