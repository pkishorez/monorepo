{
  "name": "@std-toolkit/core",
  "version": "0.0.1",
  "private": true,
  "description": "RPC related utilities for STD toolkit",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "fmt": "vp fmt",
    "lint": "vp check && pnpm lint:tsc",
    "lint:tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@std-toolkit/eschema": "workspace:*"
  },
  "devDependencies": {
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.9.1",
    "effect": "4.0.0-beta.78",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.78"
  }
}
