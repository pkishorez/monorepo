{
  "name": "@std-toolkit/db-dynamodb",
  "version": "0.0.1",
  "private": true,
  "description": "DynamoDB single-table abstraction with Effect integration and schema evolution",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "default": "./dist/rpc/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "depcruise": "depcruise-viz",
    "fmt": "vp fmt",
    "generate": "bun scripts/generate.ts",
    "lint": "vp check && pnpm lint:tsc",
    "lint:depcruise": "depcruise-viz lint",
    "lint:tsc": "tsc --noEmit",
    "play": "bun src/play/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@std-toolkit/core": "workspace:*",
    "@std-toolkit/eschema": "workspace:*",
    "aws4fetch": "1.0.20",
    "type-fest": "5.7.0"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "@monorepo/vtest": "workspace:*",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.9.1",
    "dependency-cruiser-viz": "workspace:*",
    "effect": "4.0.0-beta.78",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.78"
  }
}
