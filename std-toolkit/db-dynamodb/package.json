{
  "name": "@std-toolkit/db-dynamodb",
  "version": "0.0.1",
  "private": true,
  "description": "DynamoDB single-table abstraction with Effect integration and schema evolution",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "default": "./dist/rpc/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "fmt": "vp fmt",
    "generate": "bun scripts/generate.ts",
    "lint": "vp check",
    "play": "bun src/play/index.ts",
    "test": "vp test",
    "test:watch": "vp test --watch"
  },
  "dependencies": {
    "@std-toolkit/core": "workspace:*",
    "@std-toolkit/eschema": "workspace:*",
    "aws4fetch": "1.0.20",
    "type-fest": "5.6.0"
  },
  "devDependencies": {
    "@effect/platform": "0.96.1",
    "@effect/platform-node": "0.106.0",
    "@effect/rpc": "0.75.1",
    "@tsconfig/node22": "22.0.5",
    "@types/node": "25.6.0",
    "effect": "3.21.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "@effect/rpc": ">=0.73.0",
    "effect": ">=3.0.0"
  }
}
