{
  "name": "@pkishorez/devtools",
  "version": "0.0.1",
  "private": false,
  "description": "Local devtools RPC server for inspecting project architecture and telemetry",
  "keywords": [
    "architecture",
    "devtools",
    "effect",
    "laymos",
    "rpc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pkishorez/monorepo"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    "./rpc": "./src/rpc/index.ts",
    "./report": "./src/report/index.ts"
  },
  "bin": {
    "devtools": "dist/server/main.mjs"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vp pack",
    "build:watch": "vp pack --watch",
    "dev": "tsx src/server/main.ts",
    "lint": "vp check && tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@pkishorez/lotel": "workspace:*",
    "effect": "catalog:",
    "env-paths": "catalog:",
    "jiti": "catalog:",
    "laymos": "workspace:*",
    "std-toolkit": "workspace:*",
    "typescript": "catalog:typescript6"
  },
  "devDependencies": {
    "@typescript/native": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
