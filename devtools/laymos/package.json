{
  "name": "laymos",
  "version": "0.0.1",
  "private": false,
  "description": "Layers. Modules. Stories. Tests. Understand architecture and behavior from one place.",
  "repository": {
    "type": "git",
    "url": "https://github.com/pkishorez/monorepo"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/entrypoints/node/index.d.ts",
      "import": "./dist/entrypoints/node/index.js",
      "default": "./dist/entrypoints/node/index.js"
    },
    "./report": {
      "types": "./dist/entrypoints/report/index.d.ts",
      "import": "./dist/entrypoints/report/index.js",
      "default": "./dist/entrypoints/report/index.js"
    },
    "./story": {
      "types": "./dist/stories/authoring/index.d.ts",
      "import": "./dist/stories/authoring/index.js",
      "default": "./dist/stories/authoring/index.js"
    },
    "./test": {
      "types": "./dist/tests/authoring/index.d.ts",
      "import": "./dist/tests/authoring/index.js",
      "default": "./dist/tests/authoring/index.js"
    }
  },
  "bin": {
    "laymos": "bin/laymos.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "fmt": "vp fmt",
    "lint": "vp check && tsc && pnpm lint:laymos",
    "lint:laymos": "jiti src/entrypoints/cli/cli.ts lint",
    "test": "vitest run"
  },
  "dependencies": {
    "@ast-grep/napi": "catalog:",
    "@effect/platform-node": "catalog:",
    "jiti": "catalog:",
    "skott": "catalog:"
  },
  "devDependencies": {
    "@typescript/native": "catalog:",
    "@types/node": "catalog:",
    "effect": "catalog:",
    "typescript": "catalog:typescript6",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.78"
  },
  "publishConfig": {
    "access": "public"
  }
}
