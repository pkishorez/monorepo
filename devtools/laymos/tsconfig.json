{
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["node"],
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*", "vitest*.ts"],
  "exclude": ["dist", "node_modules", "test/fixtures"]
}
