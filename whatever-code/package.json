{
  "name": "whatever-code",
  "version": "0.0.1",
  "description": "whatever-code CLI",
  "keywords": [],
  "repository": "pkishorez/monorepo",
  "license": "MIT",
  "author": {
    "name": "Kishore"
  },
  "type": "module",
  "exports": {
    "./api/definitions": {
      "types": "./dist/api/definitions/index.d.mts",
      "import": "./dist/api/definitions/index.mjs"
    },
    "./entity": {
      "types": "./dist/entity/index.d.mts",
      "import": "./dist/entity/index.mjs"
    }
  },
  "bin": {
    "whatever": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "codex:generate": "codex app-server generate-ts --out src/codex/generated --experimental && node scripts/fix-codex-imports.mjs",
    "dev": "tsdown --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.107",
    "@effect/opentelemetry": "0.63.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-node": "0.106.0",
    "@effect/rpc": "0.75.0",
    "@openai/codex-sdk": "0.120.0",
    "@std-toolkit/eschema": "workspace:*",
    "better-sqlite3": "12.9.0",
    "effect": "3.21.0",
    "env-paths": "4.0.0",
    "node-pty": "^1.1.0",
    "ulid": "3.0.2",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.88.0",
    "@std-toolkit/core": "workspace:*",
    "@std-toolkit/db-dynamodb": "workspace:*",
    "@std-toolkit/sqlite": "workspace:*",
    "@tsconfig/node22": "22.0.5",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "tsdown": "0.21.8",
    "typescript": "6.0.2"
  }
}
