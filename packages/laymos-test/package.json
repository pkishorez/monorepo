    "test:integration": "vitest run",
    "test:stories": "laymos stories"
  },
  "dependencies": {
    "effect": "catalog:",
    "laymos": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:typescript6",
    "vitest": "catalog:"
  }
}
