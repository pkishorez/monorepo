{
  "name": "laymos-test",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end stress tests for Laymos Stories",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "fmt": "vp fmt",
    "lint": "vp check && tsc",
