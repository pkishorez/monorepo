{
  "compilerOptions": {
    "lib": ["ESNext", "Dom"],
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "declaration": true,
    "declarationMap": true,

    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true
  }
}
