{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "jsx": "react",
    "lib": ["ESNext", "DOM"],
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "*.ts", "*.tsx"],
  "exclude": ["dist", "node_modules"]
}
