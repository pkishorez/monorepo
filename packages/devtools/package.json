{
  "name": "@kishorez/devtools",
  "version": "0.0.3",
  "private": false,
  "description": "Local devtools RPC server for inspecting a project's dependency graph",
  "keywords": [
    "depcruise",
    "dependency graph",
    "devtools",
    "effect",
    "rpc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pkishorez/monorepo"
  },
  "bin": {
    "devtools": "dist/server/main.mjs"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    "./rpc": "./src/rpc/index.ts",
    "./report": "./src/report/index.ts"
  },
  "scripts": {
    "build": "vp pack",
    "build:watch": "vp pack --watch",
    "dev": "tsx src/server/main.ts",
    "lint": "vp check && tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "dependency-cruiser": "17.4.3",
    "effect": "4.0.0-beta.78",
    "jiti": "2.7.0"
  },
  "devDependencies": {
    "@kishorez/lotel": "workspace:*",
    "@types/node": "25.9.1",
    "depcruise-viz": "workspace:*",
    "std-toolkit": "workspace:*",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
