{
  "name": "dependency-cruiser-viz",
  "version": "0.0.1",
  "private": false,
  "repository": "pkishorez/monorepo",
  "bin": {
    "depcruise-viz": "dist/cli/index.js"
  },
  "files": [
    "LICENCE",
    "README.md",
    "dist/",
    "src/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "fmt": "vp fmt src test package.json tsconfig.json tsconfig.test.json depcruise.config.ts",
    "lint": "vp check src test package.json tsconfig.json tsconfig.test.json depcruise.config.ts && pnpm lint:tsc",
    "lint:depcruise": "pnpm build && node dist/cli/index.js lint",
    "lint:tsc": "tsc -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "dependency-cruiser": "17.4.3",
    "effect": "4.0.0-beta.78",
    "jiti": "2.7.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
