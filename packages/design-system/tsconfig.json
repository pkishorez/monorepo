{
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig to read more about this file */

    /* Language and Environment */
    "target": "ESNext",

    "jsx": "react",

    /* Modules */
    "module": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,

    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@utils/*": ["./src/lib/*"]
    },
    "outDir": "dist",
    "declaration": true
  }
}
