{
  "name": "@monorepo/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#lib/shadow-dom": "./src/lib/shadow-dom.tsx",
    "#lib/*": "./src/lib/*.ts",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    "./components/blocks/*": "./src/components/blocks/*/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./lib/shadow-dom": "./src/lib/shadow-dom.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./utils": "./src/lib/utils.ts",
    "./lucide": "./src/lib/lucide.ts",
    "./motion": "./src/lib/motion.ts",
    "./form": "./src/form/index.ts",
    "./styles/*": "./src/styles/*",
    "./vtest-report": "./vtest/report.json"
  },
  "scripts": {
    "addcomp": "./scripts/addcomp.sh",
    "cosmos-export": "cosmos-export",
    "dev": "cosmos",
    "lint": "vp check && tsc --noEmit",
    "test:docs": "vitest run --config vitest.docs.config.ts --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@dagrejs/dagre": "^3.0.0",
    "@emotion/is-prop-valid": "1.4.0",
    "@fontsource-variable/inter": "5.2.8",
    "@monorepo/vtest": "file:../vtest",
    "@tanstack/react-form": "1.32.0",
    "@uiw/react-json-view": "2.0.0-alpha.42",
    "@xyflow/react": "12.10.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "gray-matter": "4.0.3",
    "input-otp": "1.4.2",
    "lucide-react": "0.577.0",
    "mermaid": "11.15.0",
    "motion": "12.38.0",
    "next-themes": "0.4.6",
    "prism-react-renderer": "2.4.1",
    "react-day-picker": "10.0.1",
    "react-markdown": "9.0.1",
    "react-resizable-panels": "4.11.1",
    "recharts": "3.8.1",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "shadcn": "4.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "dependency-cruiser-viz": "workspace:*",
    "globals": "17.6.0",
    "lotel": "workspace:*",
    "react-cosmos": "7.3.0",
    "react-cosmos-plugin-vite": "7.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "react": ">=19.2.3",
    "react-dom": ">=19.2.3"
  }
}
