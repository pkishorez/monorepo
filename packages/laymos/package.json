{
  "name": "laymos",
  "version": "0.0.0",
  "private": true,
  "description": "Layers. Modules. Stories. Declare your architecture once; get enforcement and the diagram for free.",
  "repository": "pkishorez/monorepo",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./report": {
      "types": "./dist/report/index.d.ts",
      "import": "./dist/report/index.js",
      "default": "./dist/report/index.js"
    },
    "./story": {
      "types": "./dist/story/effect/index.d.ts",
      "import": "./dist/story/effect/index.js",
      "default": "./dist/story/effect/index.js"
    }
  },
  "bin": {
    "laymos": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "fmt": "vp fmt",
    "lint": "vp check && tsc --noEmit",
    "lint:laymos": "jiti src/cli/index.ts lint",
    "poc": "node poc/compare-extractors.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "effect": "catalog:",
    "jiti": "catalog:",
    "skott": "catalog:"
  },
  "devDependencies": {
    "@typescript/native": "catalog:",
    "@types/node": "catalog:",
    "dependency-cruiser": "catalog:",
    "typescript": "catalog:typescript6",
    "vitest": "catalog:"
  }
}
