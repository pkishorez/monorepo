{
  "name": "laymos",
  "version": "0.0.0",
  "private": true,
  "description": "Layers. Modules. Stories. Declare your architecture once; get enforcement and the diagram for free.",
  "repository": "pkishorez/monorepo",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./story": {
      "types": "./dist/story/core/index.d.ts",
      "import": "./dist/story/core/index.js",
      "default": "./dist/story/core/index.js"
    },
    "./story/effect": {
      "types": "./dist/story/effect/index.d.ts",
      "import": "./dist/story/effect/index.js",
      "default": "./dist/story/effect/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest/index.d.ts",
      "import": "./dist/vitest/index.js",
      "default": "./dist/vitest/index.js"
    }
  },
  "bin": {
    "laymos": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "pnpm lint:tsc",
    "lint:laymos": "jiti src/cli/index.ts lint",
    "lint:tsc": "tsc --noEmit",
    "poc": "node poc/compare-extractors.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.78",
    "effect": "4.0.0-beta.78",
    "jiti": "2.7.0",
    "skott": "0.35.11"
  },
  "peerDependencies": {
    "vitest": ">=4"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript/native": "npm:typescript@7.0.2",
    "@types/node": "26.1.0",
    "dependency-cruiser": "18.0.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vitest": "4.1.9"
  }
}
